{
  "name": "gutu-lib-ai-memory",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/ai-memory build",
    "typecheck": "bun run --cwd framework/libraries/ai-memory typecheck",
    "lint": "bun run --cwd framework/libraries/ai-memory lint",
    "test": "bun run --cwd framework/libraries/ai-memory test",
    "test:unit": "bun run --cwd framework/libraries/ai-memory test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
